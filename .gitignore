# ===============================================
# C/C++ and Ruby Extension Compilation Artifacts
# ===============================================

# --- Build system files (usually in ext/) ---
ext/**/Makefile
ext/**/mkmf.log
ext/**/conftest*

# --- Development artifact variants ---
ext/**/native.c_old
ext/**/native.c_en
ext/**/native.c_Fix
ext/**/native.c_io_uring*
ext/**/native.c_non_io_uring*

# --- Compiled Object Files ---
*.o
*.obj

# --- Compiled Shared Libraries / Binaries ---
*.so
*.bundle
*.dylib
*.dll

# --- Temporary directories from gems/extensions ---
tmp/

# --- Runtime artifacts ---
logs/
mkmf.log
perf.data
perf.data.old
rm.log
AVX
AVX.c
Makefile

# Windows image file caches
Thumbs.db
ehthumbs.db

# Folder config file
Desktop.ini

# Recycle Bin used on file shares
$RECYCLE.BIN/

# Windows Installer files
*.cab
*.msi
*.msm
*.msp

# Windows shortcuts
*.lnk

# =========================
# Operating System Files
# =========================

.DS_Store
.AppleDouble
.LSOverride

._*

.Spotlight-V100
.Trashes

.AppleDB
.AppleDesktop
Network Trash Folder
Temporary Items
.apdisk
